# =============================================================================
# SIGNER
# =============================================================================

# Storage provider (LOCAL for development)
STORAGE_PROVIDER=LOCAL

# Input/output paths (mapped via Docker volumes)
INPUT_BUCKET=/host_stream
OUTPUT_BUCKET=/host_stream
MPD_KEY=output/stream.mpd

# Signing certificates
PUB_CERT=/app/certs/ps256.pub
PRIV_KEY=/app/certs/ps256.pem

# Session key for VSI signing
SESSION_KEY_PATH=/app/certs/session.pem

# Signing method: false = ManifestBox, true = VSI
USE_VSI_METHOD=false

# Processing intervals (ms)
PUBLISH_MANIFEST_INTERVAL_MS=4000
PROCESS_INTERVAL_MS=500

# Cleanup settings
CLEANUP_MAX_AGE_MINUTES=35
CLEANUP_INTERVAL_MS=60000

# c2patool binary path
C2PATOOL_PATH=/usr/local/bin/c2patool

# Stream identifier for C2PA assertions
# STREAM_ID=

# Health check port
# HEALTH_PORT=8080

# Remote C2PA manifest URL (optional, overrides the volume-mounted manifest)
# REMOTE_C2PA_MANIFEST=

# Debug mode
DEBUG=false

# =============================================================================
# ATTACK PROXY
# =============================================================================

# Proxy server port
# PORT=8083

# Origin server URL (Docker service name)
# STATIC_SERVER_URL=http://origin-server:8081

# Base URL injected into ad-insertion MPD templates (must end with /)
# MANIFEST_BASE_URL=http://localhost:8083/

