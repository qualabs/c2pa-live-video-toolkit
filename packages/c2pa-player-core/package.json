{
  "name": "@c2pa-live-toolkit/c2pa-player-core",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Internal player-agnostic C2PA validation core. Bundled into each player plugin at build time — not published to npm.",
  "license": "Apache-2.0",
  "author": "Qualabs",
  "contributors": [
    "Nicolás Caballero <8515648+N1Knight@users.noreply.github.com>",
    "Valentina Giusti <234478367+valentinamgiusti@users.noreply.github.com>"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/qualabs/c2pa-live-video-toolkit.git",
    "directory": "packages/c2pa-player-core"
  },
  "homepage": "https://github.com/qualabs/c2pa-live-video-toolkit/tree/main/packages/c2pa-player-core",
  "bugs": {
    "url": "https://github.com/qualabs/c2pa-live-video-toolkit/issues"
  },
  "keywords": [
    "c2pa",
    "live-video",
    "provenance",
    "content-credentials",
    "validation",
    "cml"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint 'src/**/*.ts' --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@svta/cml-c2pa": "^1.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^3.0.0"
  }
}
