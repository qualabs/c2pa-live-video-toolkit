{
  "name": "@c2pa-live-toolkit/dashjs-c2pa-plugin",
  "version": "1.0.0",
  "type": "module",
  "description": "Framework-agnostic dash.js plugin for real-time C2PA segment validation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint 'src/**/*.ts' --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@flatten-js/interval-tree": "^1.1.3",
    "@svta/cml-c2pa": "file:../../../common-media-library/libs/c2pa",
    "cbor-x": "^1.5.0"
  },
  "peerDependencies": {
    "dashjs": ">=4.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "dashjs": "^4.7.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.3",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
