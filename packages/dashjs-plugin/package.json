{
  "name": "@c2pa-live-toolkit/dashjs-plugin",
  "version": "1.0.0",
  "type": "module",
  "description": "Framework-agnostic dash.js plugin for real-time C2PA segment validation",
  "license": "Apache-2.0",
  "author": "Qualabs",
  "contributors": [
    "Nicolás Caballero <8515648+N1Knight@users.noreply.github.com>",
    "Valentina Giusti <234478367+valentinamgiusti@users.noreply.github.com>"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/qualabs/c2pa-live-video-toolkit.git",
    "directory": "packages/dashjs-plugin"
  },
  "homepage": "https://github.com/qualabs/c2pa-live-video-toolkit/tree/main/packages/dashjs-plugin",
  "bugs": {
    "url": "https://github.com/qualabs/c2pa-live-video-toolkit/issues"
  },
  "keywords": [
    "c2pa",
    "dash",
    "dashjs",
    "live-video",
    "provenance",
    "content-credentials",
    "validation",
