{
  "name": "@c2pa-live-toolkit/videojs-c2pa-ui",
  "version": "1.0.0",
  "type": "module",
  "description": "Video.js UI components for C2PA validation: colored progress bar, content credentials menu, friction modal",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./styles/c2pa-player.css"
  },
  "files": ["dist", "styles", "icons", "README.md"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "video.js": ">=7.0.0"
  },
  "devDependencies": {
    "@types/video.js": "^7.3.58",
    "typescript": "^5.8.3",
    "video.js": "^8.21.0"
  }
}
