{
  "name": "@c2pa-live-toolkit/videojs-ui",
  "version": "1.0.0",
  "type": "module",
  "description": "Video.js UI components for C2PA validation: colored progress bar, content credentials menu, friction modal",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./styles/c2pa-player.css"
  },
  "files": [
    "dist",
    "styles",
    "icons",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "video.js": ">=7.0.0"
  },
  "devDependencies": {
    "@types/video.js": "^7.3.58",
    "happy-dom": "^20.8.9",
    "typescript": "^5.8.3",
    "video.js": "^8.21.0",
    "vitest": "^2.1.9"
  }
}
